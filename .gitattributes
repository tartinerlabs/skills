# Normalize line endings across platforms
* text=auto

# Shell git hooks are extensionless — declare them and force LF (CRLF breaks shebangs)
.githooks/* text eol=lf linguist-language=Shell
*.sh text eol=lf

# Go tooling requires LF
*.go text eol=lf
go.mod text eol=lf

# Generated by `xcrun agent skills export` — vendored Apple content, excluded from language stats
xcode-skills/** linguist-vendored

# Maintained by release-please — collapse diffs
CHANGELOG.md linguist-generated
